# Copy to `.env` for docker compose (gitignored).
# ECS task definition injects the same variable from Secrets Manager.

# Required for /api/v1/convert (header: X-API-Key). Prefer this name — matches ECS.
DOCLING_API_KEY=local-demo-change-me

# Optional local alias (same effect if DOCLING_API_KEY is unset):
# API_KEY=local-demo-change-me

# Opcional: con docker-compose ya va en `environment`. Si corres uvicorn a mano y quieres
# que /ui/ rellene el campo desde esta misma clave (solo local, no producción):
# DOCFLOW_UI_PREFILL_API_KEY=true

# POC / depuración (p. ej. Fly sin alinear secretos): desactiva por completo la validación X-API-Key.
# Valores: 1, true, yes, on. Por defecto está desactivado el workaround (comportamiento = PRD).
# PELIGRO: endpoint de conversión público; solo redes de confianza o ventanas cortas de prueba.
# DOCFLOW_SKIP_API_KEY_AUTH=true

# Logs del worker (Gunicorn/Uvicorn): INFO por defecto. true = DEBUG para `docflow` y `docling` (más ruido).
# DOCFLOW_DEBUG=true

# Optional tuning (docker-compose ya fija valores razonables para OCR local)
# SYNC_TIMEOUT_SECONDS=300
# GUNICORN_WORKERS=1
# GUNICORN_TIMEOUT=320
